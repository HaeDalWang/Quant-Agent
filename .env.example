# Quant-Agent 환경 변수 예시
# 이 파일을 .env로 복사해서 값을 채우세요: cp .env.example .env
# 모든 키는 QA_ 접두사를 사용합니다.

# --- 저장소 (선택, 기본값 사용 가능) ---
# QA_DATA_DIR=./data
# QA_DUCKDB_FILENAME=quant.duckdb

# --- 운영 (선택) ---
# QA_LOG_LEVEL=INFO

# --- 선택적 시크릿 (Phase 1+에서 필요) ---
# Phase 0(수집)에서는 불필요. 알림/공시 연동 시 채우세요.
# QA_DISCORD_WEBHOOK_URL=
# QA_DART_API_KEY=
