# Quant-Agent 환경 변수 예시
# 이 파일을 .env로 복사해서 값을 채우세요: cp .env.example .env
# 모든 키는 QA_ 접두사를 사용합니다.

# --- 저장소 (선택, 기본값 사용 가능) ---
# QA_DATA_DIR=./data
# QA_DUCKDB_FILENAME=quant.duckdb

# --- 운영 (선택) ---
# QA_LOG_LEVEL=INFO

# --- 시크릿 백엔드 (선택, 기본 env) ---
# env: .env/환경변수 그대로 (로컬 기본)
# aws: AWS Secrets Manager에서 로드 (클라우드 배포 시)
# QA_SECRET_BACKEND=env
# QA_AWS_SECRET_ID=quant-agent/prod      # backend=aws 일 때 필수
# QA_AWS_REGION=ap-northeast-2

# --- 선택적 시크릿 (Phase 1+에서 필요) ---
# Phase 0(수집)에서는 불필요. 알림/공시 연동 시 채우세요.
# QA_DISCORD_WEBHOOK_URL=
# QA_DART_API_KEY=

# --- 한국투자증권(KIS) API (계좌 연동, 읽기 전용 우선) ---
# 한국투자증권 KIS Developers에서 발급. 읽기 전용(잔고·보유종목)부터 시작.
# QA_KIS_APP_KEY=
# QA_KIS_APP_SECRET=
# QA_KIS_ACCOUNT_CANO=          # 계좌번호 앞 8자리
# QA_KIS_ACCOUNT_PRDT_CD=       # 계좌상품코드 뒤 2자리 (ISA 등)
# QA_KIS_PAPER_TRADING=false    # true=모의투자, false=실전
